{
  "name": "studio",
  "version": "1.0.0",
  "private": true,
  "keywords": [
    "sanity"
  ],
  "license": "UNLICENSED",
  "main": "package.json",
  "scripts": {
    "build": "sanity build",
    "deploy": "sanity deploy",
    "predev": "pnpm sanity:typegen",
    "dev": "sanity dev",
    "sanity:typegen": "sanity schema extract --enforce-required-fields --path ../sanity.schema.json && sanity typegen generate",
    "start": "sanity start",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@sanity/assist": "^5.0.4",
    "@sanity/icons": "^3.7.4",
    "@sanity/ui": "^3.1.11",
    "@sanity/vision": "^5.11.0",
    "date-fns": "^4.1.0",
    "pluralize-esm": "^9.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.5.0",
    "rxjs": "^7.8.2",
    "sanity": "^5.11.0",
    "sanity-plugin-asset-source-unsplash": "^7.0.3",
    "sanity-plugin-media": "^4.1.1",
    "styled-components": "^6.3.11"
  },
  "devDependencies": {
    "@prettier/plugin-oxc": "^0.1.3",
    "@sanity/eslint-config-studio": "^6.0.0",
    "@types/react": "^19.2.14",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3"
  }
}
