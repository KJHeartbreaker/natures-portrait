{
  "name": "web",
  "private": true,
  "scripts": {
    "prebuild": "sanity typegen generate",
    "build": "next build",
    "predev": "pnpm sanity:typegen",
    "dev": "next dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "sanity:typegen": "cd ../studio && sanity schema extract --enforce-required-fields --path ../sanity.schema.json && cd ../web && sanity typegen generate",
    "start": "next start",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@portabletext/react": "^6.0.2",
    "@sanity/client": "^7.15.0",
    "@sanity/image-url": "^2.0.3",
    "@sanity/uuid": "^3.0.2",
    "@tailwindcss/postcss": "^4.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/speed-insights": "^1.3.1",
    "autoprefixer": "^10.4.24",
    "date-fns": "^4.1.0",
    "next": "16.1.6",
    "next-sanity": "^12.1.0",
    "postcss": "^8.5.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanity": "^5.11.0",
    "sanity-image": "^1.1.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.1.6",
    "prettier-plugin-packagejson": "^3.0.0",
    "typescript": "5.9.3"
  }
}
